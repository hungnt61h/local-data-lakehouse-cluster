replicas: {{ gravitino_iceberg_rest_replica_count }}

image:
  repository: {{ gravitino_iceberg_rest_image_repository | quote }}
  tag: {{ gravitino_iceberg_rest_image_tag | quote }}
  pullPolicy: {{ gravitino_iceberg_rest_image_pull_policy }}
  pullSecrets: []

service:
  name: {{ gravitino_iceberg_rest_service_name | quote }}
  type: {{ gravitino_iceberg_rest_service_type }}
  port: {{ gravitino_iceberg_rest_service_port }}
  targetPort: {{ gravitino_iceberg_rest_service_target_port }}
  portName: http
{% if gravitino_iceberg_rest_service_type == "NodePort" and gravitino_iceberg_rest_service_node_port | string | trim | length > 0 %}
  nodePort: {{ gravitino_iceberg_rest_service_node_port }}
{% endif %}
{% if gravitino_iceberg_rest_service_annotations | length > 0 %}
  annotations:
{% for annotation_key, annotation_value in gravitino_iceberg_rest_service_annotations.items() %}
    {{ annotation_key }}: {{ annotation_value | quote }}
{% endfor %}
{% else %}
  annotations: {}
{% endif %}
{% if gravitino_iceberg_rest_service_labels | length > 0 %}
  labels:
{% for label_key, label_value in gravitino_iceberg_rest_service_labels.items() %}
    {{ label_key }}: {{ label_value | quote }}
{% endfor %}
{% else %}
  labels: {}
{% endif %}

initScript: |
{{ gravitino_iceberg_rest_init_script | indent(2, true) }}

ingress:
  enabled: {{ 'true' if gravitino_iceberg_rest_ingress_enabled else 'false' }}
{% if gravitino_iceberg_rest_ingress_class_name | trim | length > 0 %}
  className: {{ gravitino_iceberg_rest_ingress_class_name | quote }}
{% else %}
  className: ""
{% endif %}
{% if gravitino_iceberg_rest_ingress_annotations | length > 0 %}
  annotations:
{% for annotation_key, annotation_value in gravitino_iceberg_rest_ingress_annotations.items() %}
    {{ annotation_key }}: {{ annotation_value | quote }}
{% endfor %}
{% else %}
  annotations: {}
{% endif %}
  hosts:
  - host: {{ gravitino_iceberg_rest_ingress_host | quote }}
    paths:
    - path: {{ gravitino_iceberg_rest_ingress_path }}
      pathType: {{ gravitino_iceberg_rest_ingress_path_type }}
{% if gravitino_iceberg_rest_ingress_tls_enabled %}
  tls:
  - hosts:
    - {{ gravitino_iceberg_rest_ingress_host | quote }}
    secretName: {{ gravitino_iceberg_rest_ingress_tls_secret_name }}
{% else %}
  tls: []
{% endif %}

icebergRest:
  httpPort: {{ gravitino_iceberg_rest_service_target_port }}
  catalogBackend: {{ gravitino_iceberg_rest_catalog_backend | quote }}
  warehouse: {{ gravitino_iceberg_rest_warehouse | quote }}
{% if gravitino_iceberg_rest_io_impl | trim | length > 0 %}
  ioImpl: {{ gravitino_iceberg_rest_io_impl | quote }}
{% endif %}
{% if gravitino_iceberg_rest_credential_providers | trim | length > 0 %}
  credentialProviders: {{ gravitino_iceberg_rest_credential_providers | quote }}
{% endif %}
{% if gravitino_iceberg_rest_catalog_config_provider | trim | length > 0 %}
  catalogConfigProvider: {{ gravitino_iceberg_rest_catalog_config_provider | quote }}
{% endif %}
{% if gravitino_iceberg_rest_dynamic_config_provider_enabled | bool %}
  dynamicConfigProvider:
    uri: {{ gravitino_iceberg_rest_dynamic_config_provider_uri | quote }}
    metalake: {{ gravitino_iceberg_rest_dynamic_config_provider_metalake | quote }}
{% if gravitino_iceberg_rest_dynamic_config_provider_default_catalog_name | trim | length > 0 %}
    defaultCatalogName: {{ gravitino_iceberg_rest_dynamic_config_provider_default_catalog_name | quote }}
{% endif %}
{% endif %}
{% if gravitino_minio_enabled %}
  s3:
    accessKeyId: {{ gravitino_minio_access_key | quote }}
    secretAccessKey: {{ gravitino_minio_secret_key | quote }}
    endpoint: {{ gravitino_minio_endpoint_internal | quote }}
    pathStyleAccess: {{ 'true' if gravitino_minio_path_style_access else 'false' }}
{% if gravitino_minio_region | trim | length > 0 %}
    region: {{ gravitino_minio_region | quote }}
{% endif %}
{% endif %}

env:
{{ gravitino_iceberg_rest_env | to_nice_yaml(indent=2) | indent(2, true) }}
envFrom:
{{ gravitino_iceberg_rest_env_from | to_nice_yaml(indent=2) | indent(2, true) }}

resources:
{{ gravitino_iceberg_rest_resources | to_nice_yaml(indent=2) | indent(2, true) }}
extraVolumes:
{{ gravitino_iceberg_rest_extra_volumes | to_nice_yaml(indent=2) | indent(2, true) }}
extraVolumeMounts:
{{ gravitino_iceberg_rest_extra_volume_mounts | to_nice_yaml(indent=2) | indent(2, true) }}
nodeSelector:
{{ gravitino_iceberg_rest_node_selector | to_nice_yaml(indent=2) | indent(2, true) }}
tolerations:
{{ gravitino_iceberg_rest_tolerations | to_nice_yaml(indent=2) | indent(2, true) }}
affinity:
{{ gravitino_iceberg_rest_affinity | to_nice_yaml(indent=2) | indent(2, true) }}

additionalConfigItems:
{{ gravitino_iceberg_rest_additional_config_items | to_nice_yaml(indent=2) | indent(2, true) }}
