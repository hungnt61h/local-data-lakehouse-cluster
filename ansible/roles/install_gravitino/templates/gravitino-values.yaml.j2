replicas: {{ gravitino_replica_count }}

image:
  registry: {{ gravitino_image_registry | quote }}
  repository: {{ gravitino_image_repository | quote }}
  tag: {{ gravitino_image_tag | quote }}
  pullPolicy: {{ gravitino_image_pull_policy }}

service:
  name: {{ gravitino_service_name | quote }}
  type: {{ gravitino_service_type }}
  port: {{ gravitino_service_port }}
  targetPort: {{ gravitino_service_target_port }}
  portName: http
{% if gravitino_service_type == "NodePort" and gravitino_service_node_port | string | trim | length > 0 %}
  nodePort: {{ gravitino_service_node_port }}
{% endif %}
{% if gravitino_service_annotations | length > 0 %}
  annotations:
{% for annotation_key, annotation_value in gravitino_service_annotations.items() %}
    {{ annotation_key }}: {{ annotation_value | quote }}
{% endfor %}
{% else %}
  annotations: {}
{% endif %}
{% if gravitino_service_labels | length > 0 %}
  labels:
{% for label_key, label_value in gravitino_service_labels.items() %}
    {{ label_key }}: {{ label_value | quote }}
{% endfor %}
{% else %}
  labels: {}
{% endif %}

ingress:
  enabled: {{ 'true' if gravitino_ingress_enabled else 'false' }}
{% if gravitino_ingress_class_name | trim | length > 0 %}
  className: {{ gravitino_ingress_class_name | quote }}
{% else %}
  className: ""
{% endif %}
{% if gravitino_ingress_annotations | length > 0 %}
  annotations:
{% for annotation_key, annotation_value in gravitino_ingress_annotations.items() %}
    {{ annotation_key }}: {{ annotation_value | quote }}
{% endfor %}
{% else %}
  annotations: {}
{% endif %}
  hosts:
  - host: {{ gravitino_ingress_host | quote }}
    paths:
    - path: {{ gravitino_ingress_path }}
      pathType: {{ gravitino_ingress_path_type }}
{% if gravitino_ingress_tls_enabled %}
  tls:
  - hosts:
    - {{ gravitino_ingress_host | quote }}
    secretName: {{ gravitino_ingress_tls_secret_name }}
{% else %}
  tls: []
{% endif %}

entity:
  store: {{ gravitino_entity_store }}
  relationalBackend: {{ gravitino_entity_relational_backend }}
  jdbcUrl: {{ gravitino_entity_jdbc_url | quote }}
  jdbcDriver: {{ gravitino_entity_jdbc_driver | quote }}
  jdbcUser: {{ gravitino_entity_jdbc_user | quote }}
  jdbcPassword: {{ gravitino_entity_jdbc_password | quote }}
  storagePath: {{ gravitino_entity_storage_path | quote }}

authenticators: {{ gravitino_authenticators | quote }}

authorization:
  enable: {{ 'true' if gravitino_authorization_enabled else 'false' }}
  serviceAdmins: {{ gravitino_authorization_service_admins | quote }}

auxService:
  names: {{ (gravitino_aux_service_names if gravitino_iceberg_rest_enabled else '') | quote }}

icebergRest:
  httpPort: {{ gravitino_iceberg_rest_http_port }}
  catalogBackend: {{ gravitino_iceberg_rest_catalog_backend | quote }}
  warehouse: {{ gravitino_iceberg_rest_warehouse | quote }}
  ioImpl: {{ gravitino_iceberg_rest_io_impl | quote }}
{% if gravitino_minio_enabled %}
  s3:
    accessKeyId: {{ gravitino_minio_access_key | quote }}
    secretAccessKey: {{ gravitino_minio_secret_key | quote }}
    endpoint: {{ gravitino_minio_endpoint_internal | quote }}
    pathStyleAccess: {{ 'true' if gravitino_minio_path_style_access else 'false' }}
{% if gravitino_minio_region | trim | length > 0 %}
    region: {{ gravitino_minio_region | quote }}
{% endif %}
{% endif %}

{% if gravitino_iceberg_rest_enabled %}
extraExposePorts:
  - port: {{ gravitino_iceberg_rest_http_port }}
    protocol: TCP
    name: iceberg-rest-http
    targetPort: {{ gravitino_iceberg_rest_http_port }}
{% else %}
extraExposePorts: []
{% endif %}

env:
{{ gravitino_env | to_nice_yaml(indent=2) | indent(2, true) }}
envWithTpl:
{{ gravitino_env_with_tpl | to_nice_yaml(indent=2) | indent(2, true) }}
envFrom:
{{ gravitino_env_from | to_nice_yaml(indent=2) | indent(2, true) }}

extraVolumes:
{{ gravitino_extra_volumes | to_nice_yaml(indent=2) | indent(2, true) }}
extraVolumeMounts:
{{ gravitino_extra_volume_mounts | to_nice_yaml(indent=2) | indent(2, true) }}

resources:
{{ gravitino_resources | to_nice_yaml(indent=2) | indent(2, true) }}
initResources:
{{ gravitino_init_resources | to_nice_yaml(indent=2) | indent(2, true) }}
nodeSelector:
{{ gravitino_node_selector | to_nice_yaml(indent=2) | indent(2, true) }}
tolerations:
{{ gravitino_tolerations | to_nice_yaml(indent=2) | indent(2, true) }}
affinity:
{{ gravitino_affinity | to_nice_yaml(indent=2) | indent(2, true) }}

visibleConfigs: {{ gravitino_visible_configs | quote }}
visibleConfigsItems:
{{ gravitino_visible_config_items | to_nice_yaml(indent=2) | indent(2, true) }}
additionalConfigItems:
{{ gravitino_additional_config_items | to_nice_yaml(indent=2) | indent(2, true) }}

persistence:
  enabled: {{ 'true' if gravitino_persistence_enabled else 'false' }}
  accessModes:
{{ gravitino_persistence_access_modes | to_nice_yaml(indent=2) | indent(4, true) }}
  size: {{ gravitino_persistence_size | quote }}
  labels:
{{ gravitino_persistence_labels | to_nice_yaml(indent=2) | indent(4, true) }}
  annotations:
{{ gravitino_persistence_annotations | to_nice_yaml(indent=2) | indent(4, true) }}
{% if gravitino_persistence_existing_claim | trim | length > 0 %}
  existingClaim: {{ gravitino_persistence_existing_claim | quote }}
{% endif %}
{% if gravitino_persistence_storage_class_name | trim | length > 0 %}
  storageClassName: {{ gravitino_persistence_storage_class_name | quote }}
{% endif %}
