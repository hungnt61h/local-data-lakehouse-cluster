mode: {{ minio_mode }}
replicas: {{ minio_replicas }}
drivesPerNode: {{ minio_drives_per_node }}
pools: {{ minio_pools }}

{% if minio_root_user | trim | length > 0 %}
rootUser: {{ minio_root_user | quote }}
{% endif %}
{% if minio_root_password | trim | length > 0 %}
rootPassword: {{ minio_root_password | quote }}
{% endif %}

persistence:
  enabled: {{ 'true' if minio_persistence_enabled else 'false' }}
  size: {{ minio_persistence_size }}
  accessMode: {{ minio_persistence_access_mode }}
{% if minio_effective_storage_class | default('') | trim | length > 0 %}
  storageClass: {{ minio_effective_storage_class | quote }}
{% endif %}

{% if minio_node_selector | length > 0 %}
nodeSelector:
{% for node_selector_key, node_selector_value in minio_node_selector.items() %}
  {{ node_selector_key }}: {{ node_selector_value | quote }}
{% endfor %}
{% endif %}
{% if minio_tolerations | length > 0 %}
tolerations:
{{ minio_tolerations | to_nice_yaml(indent=2) | indent(2, true) }}
{% endif %}
{% if minio_affinity | length > 0 %}
affinity:
{{ minio_affinity | to_nice_yaml(indent=2) | indent(2, true) }}
{% endif %}
{% if minio_topology_spread_constraints | length > 0 %}
topologySpreadConstraints:
{{ minio_topology_spread_constraints | to_nice_yaml(indent=2) | indent(2, true) }}
{% endif %}

service:
  type: {{ minio_service_type }}
  port: "{{ minio_service_port }}"
{% if minio_service_type == "NodePort" %}
  nodePort: {{ minio_service_node_port }}
{% endif %}
{% if minio_service_type == "LoadBalancer" and minio_service_load_balancer_ip | trim | length > 0 %}
  loadBalancerIP: {{ minio_service_load_balancer_ip }}
{% endif %}

consoleService:
  type: {{ minio_console_service_type }}
  port: "{{ minio_console_service_port }}"
{% if minio_console_service_type == "NodePort" %}
  nodePort: {{ minio_console_service_node_port }}
{% endif %}
{% if minio_console_service_type == "LoadBalancer" and minio_console_service_load_balancer_ip | trim | length > 0 %}
  loadBalancerIP: {{ minio_console_service_load_balancer_ip }}
{% endif %}

ingress:
  enabled: {{ 'true' if minio_ingress_enabled else 'false' }}
{% if minio_ingress_annotations | length > 0 %}
  annotations:
{% for annotation_key, annotation_value in minio_ingress_annotations.items() %}
    {{ annotation_key }}: {{ annotation_value | quote }}
{% endfor %}
{% else %}
  annotations: {}
{% endif %}
{% if minio_ingress_class_name | trim | length > 0 %}
  ingressClassName: {{ minio_ingress_class_name }}
{% else %}
  ingressClassName: ~
{% endif %}
  path: {{ minio_ingress_path }}
  hosts:
  - {{ minio_ingress_host }}
{% if minio_ingress_tls_enabled %}
  tls:
  - secretName: {{ minio_ingress_tls_secret_name }}
    hosts:
    - {{ minio_ingress_host }}
{% else %}
  tls: []
{% endif %}

consoleIngress:
  enabled: {{ 'true' if minio_console_ingress_enabled else 'false' }}
{% if minio_console_ingress_annotations | length > 0 %}
  annotations:
{% for annotation_key, annotation_value in minio_console_ingress_annotations.items() %}
    {{ annotation_key }}: {{ annotation_value | quote }}
{% endfor %}
{% else %}
  annotations: {}
{% endif %}
{% if minio_console_ingress_class_name | trim | length > 0 %}
  ingressClassName: {{ minio_console_ingress_class_name }}
{% else %}
  ingressClassName: ~
{% endif %}
  path: {{ minio_console_ingress_path }}
  hosts:
  - {{ minio_console_ingress_host }}
{% if minio_console_ingress_tls_enabled %}
  tls:
  - secretName: {{ minio_console_ingress_tls_secret_name }}
    hosts:
    - {{ minio_console_ingress_host }}
{% else %}
  tls: []
{% endif %}

resources:
  requests:
    cpu: {{ minio_resources_requests_cpu }}
    memory: {{ minio_resources_requests_memory }}
{% if minio_resources_limits_cpu | trim | length > 0 or minio_resources_limits_memory | trim | length > 0 %}
  limits:
{% if minio_resources_limits_cpu | trim | length > 0 %}
    cpu: {{ minio_resources_limits_cpu }}
{% endif %}
{% if minio_resources_limits_memory | trim | length > 0 %}
    memory: {{ minio_resources_limits_memory }}
{% endif %}
{% endif %}
