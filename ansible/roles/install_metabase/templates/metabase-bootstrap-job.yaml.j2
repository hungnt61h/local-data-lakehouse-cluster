apiVersion: batch/v1
kind: Job
metadata:
  name: {{ metabase_bootstrap_job_name }}
  namespace: {{ metabase_namespace }}
spec:
  ttlSecondsAfterFinished: 300
  backoffLimit: 3
  template:
    metadata:
      labels:
        app: metabase-bootstrap
    spec:
      restartPolicy: OnFailure
      containers:
      - name: bootstrap
        image: {{ metabase_bootstrap_job_image | quote }}
        imagePullPolicy: IfNotPresent
        command:
        - /bin/sh
        - -ec
        - |
          set -eu
          METABASE_URL="http://{{ metabase_service_name }}.{{ metabase_namespace }}.svc.{{ metabase_cluster_domain }}:{{ metabase_service_external_port }}"

          echo "Waiting for Metabase API..."
          for i in $(seq 1 {{ metabase_bootstrap_wait_retries }}); do
            if curl -fsS "${METABASE_URL}/api/health" >/dev/null; then
              break
            fi
            if [ "${i}" -eq "{{ metabase_bootstrap_wait_retries }}" ]; then
              echo "Metabase is not healthy within timeout."
              exit 1
            fi
            sleep {{ metabase_bootstrap_wait_interval_seconds }}
          done

          SESSION_PROPERTIES="$(curl -fsS "${METABASE_URL}/api/session/properties")"
          SETUP_TOKEN="$(printf '%s' "${SESSION_PROPERTIES}" | sed -n 's/.*"setup-token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"

          if [ -z "${SETUP_TOKEN}" ]; then
            echo "Metabase already initialized; skipping bootstrap."
            exit 0
          fi

          SETUP_PAYLOAD="$(
            cat <<JSON
          {
            "token": "${SETUP_TOKEN}",
            "user": {
              "first_name": {{ metabase_admin_first_name | to_json }},
              "last_name": {{ metabase_admin_last_name | to_json }},
              "email": {{ metabase_admin_email | to_json }},
              "password": {{ metabase_admin_password | to_json }}
            },
            "prefs": {
              "site_name": {{ metabase_site_name | to_json }},
              "site_locale": {{ metabase_site_locale | to_json }}
            }
          }
          JSON
          )"

          curl -fsS -X POST "${METABASE_URL}/api/setup" \
            -H 'Content-Type: application/json' \
            -d "${SETUP_PAYLOAD}" >/tmp/metabase-bootstrap-response.json

          echo "Metabase bootstrap completed."
